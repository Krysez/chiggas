# Required
STEAM_PUBLISHER_WEB_API_KEY=REPLACE_WITH_STEAMWORKS_PUBLISHER_WEB_API_KEY

# Chiggas: Survival of the Mitiest
STEAM_APP_ID=4788490
STEAM_AUTH_IDENTITY=chiggas_inventory

# For local testing:
ALLOWED_ORIGIN=*

# For production, replace with your shipped game/site origin if applicable.
# Electron file:// origins can be tricky, so keep this flexible until final hardening.
# ALLOWED_ORIGIN=https://chiggas.uwirrldent.com

PORT=8080

# Defaults are official partner endpoints. Override only if Steamworks docs/support require it.
STEAM_AUTH_ENDPOINT=https://partner.steam-api.com/ISteamUserAuth/AuthenticateUserTicket/v1/
STEAM_INVENTORY_ENDPOINT=https://partner.steam-api.com/IInventoryService/GetInventory/v1/