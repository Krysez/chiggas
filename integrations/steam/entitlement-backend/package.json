{
  "name": "chiggas-steam-entitlement-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Secure Steam auth and inventory entitlement backend for Chiggas: Survival of the Mitiest.",
  "main": "server.js",
  "scripts": {
    "start": "node steam-microtxn-pass-99a-server.js",
    "dev": "node server.js",
    "check": "node --check server.js && node --check steam-microtxn-pass-99a-server.js && node --check scripts/health-check.js",
    "health": "node scripts/health-check.js",
    "steam:mtx:server": "node steam-microtxn-pass-99a-server.js",
    "steam:mtx:health": "node -e \"fetch('http://localhost:8791/steam/mtx/health').then(r=>r.text()).then(console.log).catch(e=>{console.error(e);process.exit(1)})\"",
    "steam:mtx:catalog": "node -e \"fetch('http://localhost:8791/steam/mtx/catalog').then(r=>r.text()).then(console.log).catch(e=>{console.error(e);process.exit(1)})\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "2.8.6",
    "express": "4.22.2",
    "helmet": "7.2.0",
    "dotenv": "16.6.1"
  }
}
