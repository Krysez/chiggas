{
  "name": "chiggas-steam-entitlement-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Secure Steam auth and inventory entitlement backend for Chiggas: Survival of the Mitiest.",
  "main": "server.js",
  "scripts": {
    "start": "node steam-microtxn-pass-99a-server.js",
    "dev": "node server.js",
    "health": "node scripts/health-check.js",
    "steam:mtx:server": "node steam-microtxn-pass-99a-server.js",
    "steam:pass99a:check": "node scripts/check-steam-pass-99a-microtxn-backend.js",
    "steam:mtx:health": "node -e \"fetch('http://localhost:8791/steam/mtx/health').then(r=>r.text()).then(console.log).catch(e=>{console.error(e);process.exit(1)})\"",
    "steam:mtx:catalog": "node -e \"fetch('http://localhost:8791/steam/mtx/catalog').then(r=>r.text()).then(console.log).catch(e=>{console.error(e);process.exit(1)})\"",
    "steam:pass99a1:check": "node scripts/check-steam-pass-99a1-env-loader.js",
    "steam:pass99b2:check": "node scripts/check-steam-pass-99b2-querytxn-get-fix.js",
    "steam:pass99b3:check": "node scripts/check-steam-pass-99b3-getreport-get-fix.js",
    "steam:pass102c:check": "node scripts/check-steam-pass-102c-catalog-names.js",
    "steam:pass102d:check": "node scripts/check-steam-pass-102d-wallet-names.js",
    "steam:pass102d1:check": "node scripts/check-steam-pass-102d1-syntax-hotfix.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "2.8.6",
    "express": "4.22.2",
    "helmet": "7.2.0",
    "dotenv": "16.6.1"
  }
}
